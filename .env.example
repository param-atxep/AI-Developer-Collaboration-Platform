# Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# DATABASE
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=foodrescue
POSTGRES_USER=foodrescue
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# KAFKA
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=foodrescue-group

# ============================================
# JWT / SECURITY
# ============================================
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ============================================
# EUREKA
# ============================================
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=eureka_secret

# ============================================
# GOOGLE MAPS
# ============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# EMAIL (SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ============================================
# AWS (for production deployment)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ECR_REGISTRY=

# ============================================
# AI MODEL
# ============================================
AI_MODEL_URL=http://localhost:5000
AI_MODEL_PATH=./ai-model/models/waste_prediction_model

# ============================================
# FRONTEND
# ============================================
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8086/ws
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
